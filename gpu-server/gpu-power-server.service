[Unit]
Description=GPU Power Server (nvidia-smi HTTP API)
After=network.target

[Service]
Type=simple
User=<username>
Group=<username>
WorkingDirectory=<path-to-script>
ExecStart=/usr/bin/python3 <path-to-script>/gpu_power_server.py --host 0.0.0.0 --port 9090
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
